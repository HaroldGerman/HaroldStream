<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F2F7">

    <!-- Contenido Principal de la Aplicación -->
    <LinearLayout
        android:id="@+id/layout_app_main_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:layout_above="@+id/layout_mini_player">

        <!-- Header con Buscador -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="14dp"
            android:paddingTop="36dp"
            android:paddingBottom="10dp"
            android:gravity="center_vertical"
            android:background="#F2F2F7">

            <EditText
                android:id="@+id/et_busqueda"
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_weight="1"
                android:hint="🔍 ¿Qué quieres escuchar?"
                android:textColorHint="#666666"
                android:textColor="#000000"
                android:textSize="14sp"
                android:paddingHorizontal="16dp"
                android:background="@drawable/bg_edittext"
                android:inputType="text"
                android:imeOptions="actionSearch" />

            <android.widget.Button
                android:id="@+id/btn_buscar"
                android:layout_width="wrap_content"
                android:layout_height="46dp"
                android:layout_marginStart="10dp"
                android:text="BUSCAR"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:paddingHorizontal="18dp"
                android:background="@drawable/bg_button_gradient" />
        </LinearLayout>

        <!-- Barra de Pestañas (Nube | Favoritas | Descargadas) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp">

            <android.widget.Button
                android:id="@+id/btn_tab_nube"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="🔍 BUSCAR"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:background="@drawable/bg_button_gradient" />

            <android.widget.Button
                android:id="@+id/btn_tab_favoritas"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:layout_marginHorizontal="2dp"
                android:text="⭐ FAVORITAS"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#666666"
                android:background="@drawable/bg_card_glowing" />

            <android.widget.Button
                android:id="@+id/btn_tab_descargadas"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="📥 OFFLINE"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#666666"
                android:background="@drawable/bg_card_glowing" />
        </LinearLayout>

        <!-- Banner de Estado Modo Offline / Error de Conexión -->
        <TextView
            android:id="@+id/tv_offline_banner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🎧 MODO OFFLINE ACTIVO"
            android:textColor="#F59E0B"
            android:textSize="12sp"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingVertical="6dp"
            android:background="#241C10"
            android:visibility="gone" />

        <!-- Título de Sección -->
        <TextView
            android:id="@+id/tv_seccion_titulo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Escuchadas recientemente"
            android:textColor="#666666"
            android:textSize="14sp"
            android:textStyle="bold"
            android:paddingHorizontal="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="4dp" />

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_margin="12dp"
            android:visibility="gone" />

        <!-- RecyclerView de lista de canciones -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_resultados"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingHorizontal="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="12dp"
            android:clipToPadding="false" />

    </LinearLayout>

    <!-- Mini-Reproductor Flotante en la Parte Inferior -->
    <LinearLayout
        android:id="@+id/layout_mini_player"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_alignParentBottom="true"
        android:layout_marginHorizontal="8dp"
        android:layout_marginBottom="8dp"
        android:orientation="horizontal"
        android:paddingHorizontal="10dp"
        android:gravity="center_vertical"
        android:background="@drawable/bg_mini_player"
        android:elevation="10dp"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <androidx.cardview.widget.CardView
            android:layout_width="42dp"
            android:layout_height="42dp"
            app:cardCornerRadius="6dp"
            app:cardElevation="0dp"
            android:backgroundTint="#F2F2F7">

            <ImageView
                android:id="@+id/iv_mini_thumb"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:contentDescription="Mini Portada" />
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_mini_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Canción"
                android:textColor="#000000"
                android:textSize="14sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tv_mini_artist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Artista"
                android:textColor="#666666"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btn_mini_play_pause"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_media_pause"
            app:tint="#000000"
            android:contentDescription="Play/Pausa" />

    </LinearLayout>

    <!-- CAPA DE AUTENTICACIÓN Y REGISTRO (OVERLAY BLOQUEADO) -->
    <LinearLayout
        android:id="@+id/layout_auth_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp"
        android:background="#F2F2F7"
        android:clickable="true"
        android:focusable="true"
        android:elevation="20dp"
        android:visibility="gone">

        <!-- VISTA 1: FORMULARIO DE REGISTRO Y SOLICITUD DE PIN -->
        <LinearLayout
            android:id="@+id/layout_registro_form"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:background="@drawable/bg_card_glowing"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔐 Registro de Usuario"
                android:textColor="#8E44AD"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ingresa tu nombre y celular para recibir tu código PIN de verificación."
                android:textColor="#666666"
                android:textSize="13sp"
                android:gravity="center"
                android:layout_marginBottom="20dp" />

            <EditText
                android:id="@+id/et_reg_nombre"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="👤 Nombre y Apellido"
                android:textColorHint="#666666"
                android:textColor="#000000"
                android:textSize="14sp"
                android:paddingHorizontal="16dp"
                android:background="@drawable/bg_edittext"
                android:inputType="textPersonName"
                android:layout_marginBottom="12dp" />

            <EditText
                android:id="@+id/et_reg_telefono"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="📱 Número de Celular"
                android:textColorHint="#666666"
                android:textColor="#000000"
                android:textSize="14sp"
                android:paddingHorizontal="16dp"
                android:background="@drawable/bg_edittext"
                android:inputType="phone"
                android:layout_marginBottom="20dp" />

            <android.widget.Button
                android:id="@+id/btn_reg_enviar"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="SOLICITAR CÓDIGO PIN"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:background="@drawable/bg_button_gradient" />

        </LinearLayout>

        <!-- VISTA 2: FORMULARIO DE INGRESO DE CÓDIGO PIN DE 4 DÍGITOS -->
        <LinearLayout
            android:id="@+id/layout_codigo_form"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:background="@drawable/bg_card_glowing"
            android:padding="24dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔑 Código de Verificación"
                android:textColor="#0284C7"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/tv_codigo_instruccion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ingresa el código PIN de 4 dígitos enviado a tu dispositivo:"
                android:textColor="#666666"
                android:textSize="13sp"
                android:gravity="center"
                android:layout_marginBottom="20dp" />

            <EditText
                android:id="@+id/et_reg_pin"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="🔑 PIN de 4 dígitos"
                android:textColorHint="#666666"
                android:textColor="#34D399"
                android:textSize="22sp"
                android:textStyle="bold"
                android:gravity="center"
                android:maxLength="4"
                android:paddingHorizontal="16dp"
                android:background="@drawable/bg_edittext"
                android:inputType="number"
                android:layout_marginBottom="20dp" />

            <android.widget.Button
                android:id="@+id/btn_verificar_pin"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="VERIFICAR CÓDIGO PIN"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:background="@drawable/bg_button_gradient" />

        </LinearLayout>

        <!-- VISTA 3: PANTALLA DE PENDIENTE DE APROBACIÓN POR ADMIN -->
        <LinearLayout
            android:id="@+id/layout_pendiente_form"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:background="@drawable/bg_card_glowing"
            android:padding="24dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏳ Esperando Aprobación"
                android:textColor="#F59E0B"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tv_pendiente_mensaje"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="¡Código PIN verificado con éxito! Tu dispositivo ya aparece en el Panel Administrador. Espera a que Harold lo apruebe."
                android:textColor="#666666"
                android:textSize="14sp"
                android:gravity="center"
                android:layout_marginBottom="24dp" />

            <android.widget.Button
                android:id="@+id/btn_verificar_estado"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="🔄 VERIFICAR APROBACIÓN"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:background="@drawable/bg_button_gradient" />

        </LinearLayout>

    </LinearLayout>

</RelativeLayout>
