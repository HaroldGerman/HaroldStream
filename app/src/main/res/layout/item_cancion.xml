<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="10dp"
    android:layout_marginVertical="3dp"
    android:background="@drawable/bg_card_glowing"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical">

    <androidx.cardview.widget.CardView
        android:layout_width="52dp"
        android:layout_height="52dp"
        app:cardCornerRadius="6dp"
        app:cardElevation="0dp"
        android:backgroundTint="#E5E5EA">

        <ImageView
            android:id="@+id/iv_thumbnail"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:contentDescription="Portada" />
    </androidx.cardview.widget.CardView>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="14dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_titulo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textColor="#000000"
            android:textStyle="bold"
            android:maxLines="2"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/tv_subtitulo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:textSize="13sp"
            android:textColor="#666666"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>

    <!-- Botón estilo Spotify (+ / Check) -->
    <ImageButton
        android:id="@+id/btn_favorito"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_spotify_plus"
        android:contentDescription="Agregar a Favoritos"
        android:layout_marginEnd="4dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="▶"
        android:textColor="#672da8"
        android:textSize="16sp"
        android:layout_marginStart="4dp" />

</LinearLayout>
