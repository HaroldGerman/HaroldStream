<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F2F2F7"
    android:paddingHorizontal="20dp"
    android:paddingTop="36dp"
    android:paddingBottom="20dp"
    android:gravity="center_horizontal">

    <!-- Header superior con botón colapsar (Flecha abajo v estilo Spotify) y Botón (+ / Check) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <ImageButton
            android:id="@+id/btn_collapse"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/arrow_down_float"
            app:tint="#000000"
            android:contentDescription="Colapsar a mini reproductor" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="REPRODUCIENDO"
            android:textColor="#000000"
            android:textSize="12sp"
            android:textStyle="bold"
            android:gravity="center" />

        <ImageButton
            android:id="@+id/btn_player_star"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_spotify_plus"
            android:contentDescription="Agregar a Favoritos" />
    </LinearLayout>

    <!-- Portada del Álbum con CardView y Sombra Elevada -->
    <androidx.cardview.widget.CardView
        android:layout_width="260dp"
        android:layout_height="260dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="12dp"
        android:backgroundTint="#242424"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="24dp">

        <ImageView
            android:id="@+id/iv_player_cover"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:contentDescription="Portada" />
    </androidx.cardview.widget.CardView>

    <!-- Título de la canción -->
    <TextView
        android:id="@+id/tv_player_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Título de la Canción"
        android:textColor="#000000"
        android:textSize="20sp"
        android:textStyle="bold"
        android:gravity="center"
        android:maxLines="2"
        android:ellipsize="end"
        android:layout_marginBottom="4dp" />

    <!-- Artista / Canal -->
    <TextView
        android:id="@+id/tv_player_artist"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Canal / Artista"
        android:textColor="#666666"
        android:textSize="14sp"
        android:gravity="center"
        android:maxLines="1"
        android:ellipsize="end"
        android:layout_marginBottom="20dp" />

    <!-- Barra de Tiempo (SeekBar) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="16dp">

        <SeekBar
            android:id="@+id/sb_progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:progressBackgroundTint="#333333"
            android:progressTint="#8E44AD"
            android:thumbTint="#000000" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="14dp"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/tv_current_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="#666666"
                android:textSize="12sp" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tv_total_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="#666666"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Controles Principales: Canción Anterior ⏮️ | Play/Pausa ⏯️ | Canción Siguiente ⏭️ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="24dp">

        <ImageButton
            android:id="@+id/btn_rewind"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_media_previous"
            app:tint="#000000"
            android:contentDescription="Canción Anterior" />

        <ImageButton
            android:id="@+id/btn_play_pause"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_marginHorizontal="28dp"
            android:background="@drawable/bg_button_gradient"
            android:src="@android:drawable/ic_media_pause"
            app:tint="#000000"
            android:contentDescription="Play o Pausa" />

        <ImageButton
            android:id="@+id/btn_forward"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_media_next"
            app:tint="#000000"
            android:contentDescription="Canción Siguiente" />
    </LinearLayout>

    <!-- Botón Descargar MP3 en Celular -->
    <android.widget.Button
        android:id="@+id/btn_download_mobile"
        android:layout_width="90dp"
        android:layout_height="20dp"
        android:text="⬇ DESCARGAR"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:background="@drawable/bg_button_pink" />

    <!-- Espacio flexible para empujar la marca al fondo -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Branding Footer (Marca de Agua) -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="HaroldSound"
        android:textColor="#555555"
        android:textSize="12sp"
        android:textStyle="bold"
        android:letterSpacing="0.2"
        android:layout_marginBottom="4dp" />

</LinearLayout>
